OPENAI_API_KEY=
OPENAI_MODELS=gpt-5-mini,gpt-5.4
OPENAI_BASE_URL=
OPENAI_REQUEST_TIMEOUT_MS=45000
MAX_CONTEXT_MESSAGES=8

# Discord application config.
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# Optional. If set, `npm run discord:register` registers guild commands for
# faster iteration. Leave empty to register global commands instead.
DISCORD_GUILD_ID=

# Preferred prompt override key for the Workers API.
SYSTEM_PROMPT=

# Backward-compatible alias. Use SYSTEM_PROMPT for new deployments.
BOT_SYSTEM_PROMPT=

# Dosu HTTP MCP config.
# Preferred: provide deployment ID and API key, and the worker will build:
# https://api.dosu.dev/v1/mcp/deployments/<deployment-id>
DOSU_MCP_DEPLOYMENT_ID=
DOSU_MCP_API_KEY=

# Optional: provide the full MCP endpoint directly instead of deployment ID.
DOSU_MCP_SERVER_URL=
DOSU_MCP_BASE_URL=https://api.dosu.dev/v1/mcp

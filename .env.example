DISCORD_BOT_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_REQUIRE_MENTION=
MAX_CONTEXT_MESSAGES=8
OPENAI_REQUEST_TIMEOUT_MS=45000

# Dosu HTTP MCP config.
# Recommended: provide deployment ID and API key, and the app will build:
# https://api.dosu.dev/v1/mcp/deployments/<deployment-id>
DOSU_MCP_DEPLOYMENT_ID=
DOSU_MCP_API_KEY=
DOSU_MCP_SERVER_URL=
DOSU_MCP_BASE_URL=https://api.dosu.dev/v1/mcp

# Optional custom system prompt.
BOT_SYSTEM_PROMPT=
